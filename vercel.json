{
  "buildCommand": "npm install",
  "devCommand": "node server.js",
  "installCommand": "npm install",
  "framework": "express",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
