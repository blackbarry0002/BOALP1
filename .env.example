# Bank of America Login - Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
# Set to 'production' for Vercel deployment, 'development' for local testing
NODE_ENV=production

# Port for local development (Vercel ignores this, default: 3000)
PORT=3000

# ============================================================================
# SUPABASE CONFIGURATION (REQUIRED FOR PRODUCTION)
# ============================================================================
# Get these values from your Supabase project dashboard:
# 1. Go to https://supabase.com and sign in to your account
# 2. Select your project (or create a new one)
# 3. Go to Settings → API
# 4. Copy the values below

# Your Supabase project URL
# Format: https://xxxxx.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous key (used for client-side requests)
# This is safe to expose in the browser
SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# NOTES
# ============================================================================
# - Local Development: Create a .env file with values from Supabase
# - Vercel Deployment: Add these variables in Vercel Project Settings → Environment Variables
# - DO NOT commit .env to Git (it's in .gitignore)
# - Keep your Supabase keys private but safe (the ANON_KEY is publicly safe)

